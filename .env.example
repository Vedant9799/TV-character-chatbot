# Copy this file to .env and fill in your token
# .env is already in .gitignore — never commit real tokens
#
# Hugging Face token (required when using --use-inference-api)
# Create at: https://huggingface.co/settings/tokens
# Permission: Inference or Inference Providers
HF_TOKEN=

# Retrieval debug (optional): log input/output/scoring to retrieval_debug.log
# RETRIEVAL_DEBUG=1
# RETRIEVAL_DEBUG_STDOUT=1
