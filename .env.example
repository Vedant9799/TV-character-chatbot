# Copy this file to .env and fill in your values.
# .env is in .gitignore — never commit real secrets.

# ── Backend (Render) ──────────────────────────────────────────────────────────

# Groq API key — get one free at https://console.groq.com
GROQ_API_KEY=your_groq_api_key_here

# Supabase project credentials — Dashboard → Settings → API
# Use the service-role key (not the anon key) — it bypasses row-level security
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# ── Frontend (Vercel environment variables) ────────────────────────────────────
# Set these in the Vercel dashboard under Project → Settings → Environment Variables.
# They are baked into the JS bundle at build time (VITE_ prefix is required).

# Render hostname of the primary backend (server.py / Qwen3).
# No protocol prefix, no trailing slash. Example: my-chatbot-qwen.onrender.com
VITE_BACKEND_URL=

# Compare-mode backends — left panel (A) and right panel (B).
# Leave blank to use localhost:8001 / localhost:8002 in local dev.
VITE_COMPARE_A=my-chatbot-qwen.onrender.com
VITE_COMPARE_B=my-chatbot-llama.onrender.com
